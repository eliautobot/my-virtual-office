# Virtual Office Configuration
# Copy this file to .env and adjust values for your setup.

# Path to your OpenClaw installation
VO_OPENCLAW_PATH=~/.openclaw

# OpenClaw gateway connection (default works for local installs)
VO_GATEWAY_URL=ws://127.0.0.1:18789
VO_GATEWAY_HTTP=http://127.0.0.1:18789

# Server ports (uses host networking, so these bind directly)
VO_PORT=8090
VO_WS_PORT=8091

# Office display name
VO_OFFICE_NAME=Virtual Office

# Weather widget location (optional, e.g. "New+York,NY")
VO_WEATHER_LOCATION=

# Agent Browser VNC password (if using the optional browser service)
# BROWSER_VNC_PASSWORD=changeme
